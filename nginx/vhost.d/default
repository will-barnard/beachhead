# Serve ACME HTTP-01 challenge files directly from the shared html volume.
# This must take priority over the proxy_pass to the backend so Let's Encrypt
# can verify domain ownership without the backend intercepting the request.
location ^~ /.well-known/acme-challenge/ {
    auth_basic off;
    allow all;
    root /usr/share/nginx/html;
    try_files $uri =404;
    break;
}

client_max_body_size 8192m;

# Allow large uploads (e.g. 6 GB static site zips) to transfer without timing out.
proxy_read_timeout 3600s;
proxy_send_timeout 3600s;
client_body_timeout 3600s;
