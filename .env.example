# Beachhead Configuration — copy to .env and fill in
NODE_ENV=production
PORT=3000

# Domain — your Beachhead dashboard/API domain
BEACHHEAD_DOMAIN=deploy.example.com

# SSL — email for LetsEncrypt certificate notifications
LETSENCRYPT_EMAIL=admin@example.com

# Database
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://beachhead:changeme@beachhead-db:5432/beachhead

# Auth (leave empty for bootstrap mode — no auth required)
# Once auth service is deployed, set to the auth service's JWKS URL
AUTH_JWKS_URL=
AUTH_ISSUER=

# GitHub — default webhook secret (can be overridden per-app)
GITHUB_WEBHOOK_SECRET=

# Deployment
# Linux default: /var/beachhead/deployments
# macOS default: $HOME/beachhead/deployments  (under /Users which Docker Desktop shares with its VM by default)
# IMPORTANT: this path is bind-mounted at the same path inside the beachhead container,
# so changing it requires both halves to match. install.sh handles this automatically.
DEPLOY_BASE_DIR=/var/beachhead/deployments
DOCKER_NETWORK=beachhead-net

# Health Check
HEALTH_CHECK_TIMEOUT=30000
HEALTH_CHECK_INTERVAL=2000
